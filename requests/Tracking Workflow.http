### =================================================================
### ZWISCHENTEST: ONBOARDING & LIMIT-SETZUNG
### =================================================================

@baseUrl = http://192.168.1.200:3000
@adminKey = MASTER_ADMIN_2026
@newSupplierKey = SUPPLIER_B_TOKEN_99
@newSupplierName = Lieferant_B
@newSupplierPass = start123
@deliveryId = SHIP-2026-B-TEST
@sensorHardwareId = ESP_99

### -----------------------------------------------------------------
### SCHRITT 1: Lieferant im System aufnehmen (ADMIN-AKTION)
### -----------------------------------------------------------------
# Erstellt den Account in SQLite und das SUPPLIER-Asset auf der Blockchain
### SCHRITT 1: Lieferant im System aufnehmen
POST {{baseUrl}}/api/admin/onboard-supplier
x-api-key: {{adminKey}}
Content-Type: application/json

{
    "supplierName": "{{newSupplierName}}",
    "password": "{{newSupplierPass}}",
    "apiKey": "{{newSupplierKey}}"
}

### -----------------------------------------------------------------
### SCHRITT 2: Lieferung registrieren (SUPPLIER-AKTION)
### -----------------------------------------------------------------
# Der Lieferant nutzt SEINEN neuen Key.
# Status in DB wird 'PENDING_LIMITS'. Blockchain initialisiert die Lieferung.
POST {{baseUrl}}/api/supplier/onboard
x-api-key: {{newSupplierKey}}
Content-Type: application/json

{
    "hardwareId": "{{sensorHardwareId}}",
    "deliveryId": "{{deliveryId}}"
}

### -----------------------------------------------------------------
### SCHRITT 3: Grenzwerte versiegeln (SUPPLIER-AKTION)
### -----------------------------------------------------------------
# Nutzt die DeliveryId in der URL.
# Status in DB wird 'IN_TRANSIT'. Blockchain speichert LIMIT-Composite-Key.
POST {{baseUrl}}/api/supplier/set-limit/{{deliveryId}}
x-api-key: {{newSupplierKey}}
Content-Type: application/json

{
    "maxTemp": 8.0,
    "minTemp": 2.0,
    "maxHum": 60.0,
    "minHum": 40.0
}

### -----------------------------------------------------------------
### SCHRITT 4: Sensordaten einspeisen (GATEWAY/ESP8266 AKTION)
### -----------------------------------------------------------------
# Simuliert den ESP8266, der Daten an das Gateway sendet.
# Das Gateway prüft gegen die versiegelten Limits aus Schritt 3.
### SCHRITT 4: Sensordaten einspeisen
POST {{baseUrl}}/api/buffer
x-api-key: {{newSupplierKey}}
Content-Type: application/json

{
    "sensorId": "ESP_99",
    "temperature": 24.5,
    "humidity": 50.0,
    "lat": 52.5200,
    "lon": 13.4050,
    "timestamp": "2026-03-19T18:00:00Z"
}

### -----------------------------------------------------------------
### SCHRITT 5: Alarme prüfen (SUPPLIER-ANSICHT)
### -----------------------------------------------------------------
# Der Lieferant prüft, ob Grenzwerte überschritten wurden.
GET {{baseUrl}}/api/supplier/alerts
x-api-key: {{newSupplierKey}}

### -----------------------------------------------------------------
### SCHRITT 6: Historie abrufen (SUPPLIER-ANSICHT)
### -----------------------------------------------------------------
# Spezifische Historie für die Test-Lieferung.
GET {{baseUrl}}/api/supplier/history/{{deliveryId}}
x-api-key: {{newSupplierKey}}

### -----------------------------------------------------------------
### SCHRITT 7: Globale Überwachung (ADMIN-ANSICHT)
### -----------------------------------------------------------------
# Der Admin (Großunternehmen) sieht ALLE Alarme systemweit.
GET {{baseUrl}}/api/admin/alerts
x-api-key: {{adminKey}}

### -----------------------------------------------------------------
### SCHRITT 8: Erhalt bestätigen (Admin/Empfänger)
### -----------------------------------------------------------------
POST {{baseUrl}}/api/admin/confirm-receipt/{{newSupplierName}}/{{deliveryId}}
x-api-key: {{adminKey}}
Content-Type: application/json

{
    "recipientName": "Zentrallager Berlin"
}

### -----------------------------------------------------------------
### SCHRITT 9: Lieferung finalisieren (Admin/Supplier)
### -----------------------------------------------------------------
POST {{baseUrl}}/api/admin/final-checkout/{{newSupplierName}}/{{deliveryId}}
x-api-key: {{adminKey}}

app.get('/api/supplier/:supplier/audit/:deliveryId', supplierAuth, async (req, res) => {


###
GET {{baseUrl}}/api/supplier/{{newSupplierName}}/audit/{{deliveryId}}
x-api-key: {{newSupplierKey}}
Content-Type: application/json

### SCHRITT 10a: Report Download (ADMIN-Sicht)
# Ersetze {{deliveryId}} durch eine ID, die bereits im Status 'CLOSED' ist
GET {{baseUrl}}/api/admin/download-report/SHIP-2026-B-TEST
x-api-key: MASTER_ADMIN_2026
Content-Type: application/json